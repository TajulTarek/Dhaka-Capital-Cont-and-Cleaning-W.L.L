# ──────────────────────────────────────────────────────────────────────────────
# Dhaka Capital Contracting and Cleaning W.L.L  –  Website Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.

# ── SMTP / Email (for the Contact form) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false          # set to "true" for port 465
SMTP_USER=dhkcptl@gmail.com
SMTP_PASS=your-app-password

# Recipient of contact-form submissions
TO_EMAIL=dhkcptl@gmail.com
